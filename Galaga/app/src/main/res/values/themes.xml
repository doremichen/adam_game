<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Galaga" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="PreferenceTheme.Galaga" parent="@style/PreferenceThemeOverlay.v14.Material">
        <item name="preferenceCategoryStyle">@style/PreferenceCategory.Galaga</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
    </style>
    <style name="Theme.Galaga.Settings" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="preferenceTheme">@style/PreferenceTheme.Galaga</item>
        <item name="android:windowActionBarOverlay">false</item>
        <item name="android:windowNoTitle">false</item>
    </style>
    <style name="PreferenceCategory.Galaga" parent="Preference.Category.Material">
        <item name="android:layout">@layout/custom_preference_category</item>
    </style>
    <style name="shape_circle" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="shape_rounded_medium" parent="">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="shape_cut" parent="">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>