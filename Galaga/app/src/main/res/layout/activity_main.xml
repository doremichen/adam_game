<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.adam.app.galaga.viewmodel.MainViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="?attr/colorSurface">

        <com.adam.app.galaga.ui.main.GamePreviewSurfaceView
            android:id="@+id/gamePreview"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:layout_marginTop="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/galaga_game_name"
            android:textColor="#00E5FF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/gamePreview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-20dp"/>

<!--        <com.google.android.material.imageview.ShapeableImageView-->
<!--            android:id="@+id/ivLogo"-->
<!--            android:layout_width="280dp"-->
<!--            android:layout_height="180dp"-->
<!--            android:layout_marginTop="80dp"-->
<!--            android:scaleType="centerInside"-->
<!--            android:src="@drawable/ic_game_logo"-->
<!--            app:layout_constraintEnd_toEndOf="parent"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintTop_toTopOf="parent" />-->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="240dp"
            android:layout_height="64dp"
            android:text="@string/galaga_main_start_game_btn"
            android:onClick="@{() -> viewModel.onStartGame()}"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            app:layout_constraintBottom_toTopOf="@+id/btnSettings"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvMainTitle"
            app:layout_constraintVertical_chainStyle="packed" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/galaga_main_settings_btn"
            android:onClick="@{() -> viewModel.onOpenSettings()}"
            app:layout_constraintBottom_toTopOf="@+id/btnLeaderboard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeaderboard"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/galaga_main_leaderboard_btn"
            android:onClick="@{() -> viewModel.onOpenLeaderBoard()}"
            app:layout_constraintBottom_toTopOf="@+id/btnAbout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnSettings" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAbout"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/galaga_main_about_btn"
            android:onClick="@{() -> viewModel.onOpenAbout()}"
            app:layout_constraintBottom_toTopOf="@+id/btnExit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnLeaderboard" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExit"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/galaga_exit_btn"
            android:onClick="@{() -> viewModel.onExit()}"
            android:textColor="?attr/colorError"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnAbout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>