<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Same high-quality gaming theme for night mode -->
    <style name="Theme.TetrisGame" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/game_accent_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/game_accent_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/game_bg_deep</item>
        <item name="colorSurface">@color/game_surface_dark</item>
        <item name="colorOnSurface">@color/game_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/game_text_secondary</item>

        <item name="android:statusBarColor">@color/game_bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>