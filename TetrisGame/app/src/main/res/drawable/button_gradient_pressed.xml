<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="16dp" />

    <gradient
        android:startColor="#2563EB"
        android:centerColor="#1D4ED8"
        android:endColor="#1E40AF"
        android:angle="45"
        android:type="linear" />

    <stroke
        android:width="1dp"
        android:color="#60FFFFFF" />

    <padding
        android:left="24dp"
        android:top="12dp"
        android:right="24dp"
        android:bottom="12dp" />
</shape>